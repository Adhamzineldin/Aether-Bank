@startuml
title DB 03 — Core Ledger & Transaction Service (PostgreSQL)

skinparam linetype ortho
skinparam classBackgroundColor #FCE4EC
skinparam classBorderColor #880E4F
skinparam classHeaderBackgroundColor #F48FB1
skinparam classFontStyle bold
skinparam classAttributeFontSize 11

entity "ledger_accounts" as LA {
  * id                  : UUID         <<PK>>
  --
  * external_account_id : UUID         <<UNIQUE>>
  * balance             : DECIMAL(18,2)
  * currency            : CHAR(3)
  * last_updated        : TIMESTAMP
}

entity "transactions" as TX {
  * id               : UUID         <<PK>>
  --
  * type             : ENUM(DEPOSIT, WITHDRAWAL, TRANSFER, FEE)
  * status           : ENUM(PENDING, COMPLETED, FAILED, ROLLED_BACK)
  * amount           : DECIMAL(18,2)
  * currency         : CHAR(3)
  * reference_number : VARCHAR(50)   <<UNIQUE>>
  * description      : VARCHAR(255)
  * initiated_by     : UUID
  * created_at       : TIMESTAMP
  * completed_at     : TIMESTAMP
}

entity "journal_entries" as JE {
  * id                : UUID         <<PK>>
  --
  * transaction_id    : UUID         <<FK>>
  * ledger_account_id : UUID         <<FK>>
  * entry_type        : ENUM(DEBIT, CREDIT)
  * amount            : DECIMAL(18,2)
  * entry_date        : TIMESTAMP
}

entity "transfer_details" as TD {
  * id              : UUID          <<PK>>
  --
  * transaction_id  : UUID          <<FK>>
  * from_account_id : UUID          <<FK>>
  * to_account_id   : UUID          <<FK>>
  * transfer_type   : ENUM(INTERNAL, EXTERNAL, WIRE)
  * exchange_rate   : DECIMAL(18,6)
}

entity "balance_snapshots" as BS {
  * id                : UUID          <<PK>>
  --
  * ledger_account_id : UUID          <<FK>>
  * snapshot_date     : DATE
  * closing_balance   : DECIMAL(18,2)
  * total_credits     : DECIMAL(18,2)
  * total_debits      : DECIMAL(18,2)
}

LA ||--o{ JE : "has entries"
TX ||--o{ JE : "produces"
TX ||--o| TD : "has details"
LA ||--o{ BS : "archived in"

note bottom of TX
  Every monetary operation produces
  exactly TWO journal_entries:
  one DEBIT and one CREDIT.
  PostgreSQL ACID ensures atomicity.
end note
@enduml
