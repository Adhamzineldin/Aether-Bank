@startuml
title DB 05 — Card & External Gateway Service (MySQL)

skinparam linetype ortho
skinparam classBackgroundColor #E0F7FA
skinparam classBorderColor #006064
skinparam classHeaderBackgroundColor #B2EBF2
skinparam classFontStyle bold
skinparam classAttributeFontSize 11

entity "cards" as CARD {
  * id               : VARCHAR(36) <<PK>>
  --
  * account_id       : VARCHAR(36)
  * customer_id      : VARCHAR(36)
  * card_number_hash : VARCHAR(255)
  * card_token       : VARCHAR(255) <<UNIQUE>>
  * last_four_digits : CHAR(4)
  * card_type        : ENUM(CREDIT, DEBIT)
  * card_network     : ENUM(VISA, MASTERCARD, AMEX)
  * status           : ENUM(PENDING, ACTIVE, BLOCKED, EXPIRED)
  * expiry_month     : TINYINT
  * expiry_year      : SMALLINT
  * cvv_hash         : VARCHAR(255)
  * issued_at        : TIMESTAMP
  * activated_at     : TIMESTAMP
  * blocked_at       : TIMESTAMP
  * block_reason     : VARCHAR(255)
}

entity "credit_card_details" as CC {
  * id                  : VARCHAR(36) <<PK>>
  --
  * card_id             : VARCHAR(36) <<FK>> <<UNIQUE>>
  * credit_limit        : DECIMAL(12,2)
  * available_credit    : DECIMAL(12,2)
  * current_balance     : DECIMAL(12,2)
  * minimum_payment     : DECIMAL(12,2)
  * payment_due_date    : DATE
  * annual_interest_rate : DECIMAL(5,2)
  * billing_cycle_day   : TINYINT
  * last_statement_date : DATE
}

entity "card_transactions" as CTX {
  * id                     : VARCHAR(36) <<PK>>
  --
  * card_id                : VARCHAR(36) <<FK>>
  * merchant_id            : VARCHAR(36) <<FK>>
  * amount                 : DECIMAL(12,2)
  * currency               : CHAR(3)
  * amount_in_base_currency : DECIMAL(12,2)
  * exchange_rate          : DECIMAL(12,6)
  * status                 : ENUM(PENDING, APPROVED, DECLINED, REFUNDED, VOIDED)
  * type                   : ENUM(PURCHASE, REFUND, VOID, CASH_ADVANCE)
  * auth_code              : VARCHAR(20)
  * ledger_tx_id           : VARCHAR(36)
  * created_at             : TIMESTAMP
  * settled_at             : TIMESTAMP
}

entity "merchants" as MERCH {
  * id           : VARCHAR(36) <<PK>>
  --
  * name         : VARCHAR(255)
  * api_key_hash : VARCHAR(255) <<UNIQUE>>
  * category     : VARCHAR(100)
  * country      : VARCHAR(100)
  * is_active    : BOOLEAN
  * registered_at : TIMESTAMP
}

entity "exchange_rate_cache" as FX {
  * id              : INT         <<PK>>
  --
  * base_currency   : CHAR(3)
  * target_currency : CHAR(3)
  * rate            : DECIMAL(18,6)
  * fetched_at      : TIMESTAMP
  * expires_at      : TIMESTAMP
}

CARD  ||--o| CC    : "extends (credit only)"
CARD  ||--o{ CTX   : "has transactions"
MERCH ||--o{ CTX   : "processes"

note bottom of CARD
  card_number_hash: AES-256 encrypted.
  card_token: public-facing tokenized PAN
  (PCI-DSS compliance).
  exchange_rate_cache TTL = 15 minutes.
end note
@enduml
