@startuml
title Sequence 01 — User Login with JWT & Optional 2FA

skinparam sequenceArrowThickness 2
skinparam sequenceGroupBorderColor #1565C0
skinparam participantBackgroundColor #E3F2FD
skinparam participantBorderColor #1565C0
skinparam participantFontStyle bold
skinparam sequenceLifeLineBorderColor #90CAF9
skinparam noteBorderColor #F57F17
skinparam noteBackgroundColor #FFF9C4
skinparam responseMessageBelowArrow true

actor        Customer
participant  "React Frontend"          as FE
participant  "API Gateway"             as GW
participant  "IAM Service"             as IAM
database     "PostgreSQL (IAM DB)"     as DB
participant  "Kafka"                   as KAFKA
participant  "Notification Service"    as NOTIF

Customer -> FE    : Enter email + password
FE       -> GW    : POST /api/auth/login\n{ email, password }
GW       -> IAM   : Route → IAM Service

activate IAM
IAM -> DB : SELECT user WHERE email = ?
DB --> IAM : user record { passwordHash, role, twoFaEnabled }

alt Invalid Credentials
    IAM --> GW : 401 Unauthorized
    GW  --> FE : 401 Unauthorized
    FE  --> Customer : "Invalid email or password"

else Valid Credentials
    IAM -> IAM : BCrypt.verify(password, hash)

    alt 2FA Enabled
        IAM -> IAM  : Generate 6-digit OTP
        IAM -> KAFKA : Publish LoginOTPRequestedEvent\n{ userId, otp, email }
        KAFKA -> NOTIF : Consume LoginOTPRequestedEvent
        NOTIF -> Customer : Send OTP via Email / SMS

        IAM --> GW   : 202 Accepted { message: "OTP sent" }
        GW  --> FE   : 202 OTP Pending
        Customer -> FE : Enter OTP code
        FE -> GW : POST /api/auth/verify-otp\n{ userId, otp }
        GW -> IAM : Verify OTP

        alt OTP Invalid or Expired
            IAM --> GW : 401 OTP Invalid
            GW  --> FE : 401
            FE  --> Customer : "Invalid OTP"

        else OTP Valid
            IAM -> IAM : Generate JWT (15 min) + Refresh Token (7 days)
            IAM -> DB  : INSERT refresh_token record
            IAM --> GW : 200 OK { accessToken, refreshToken, role }
            GW  --> FE : 200 + Tokens
            FE  -> FE  : Store tokens (HttpOnly cookie)
            FE  --> Customer : Redirect to Dashboard
        end

    else 2FA Disabled
        IAM -> IAM : Generate JWT (15 min) + Refresh Token (7 days)
        IAM -> DB  : INSERT refresh_token record
        IAM --> GW : 200 OK { accessToken, refreshToken, role }
        GW  --> FE : 200 + Tokens
        FE  -> FE  : Store tokens
        FE  --> Customer : Redirect to Dashboard
    end
end

deactivate IAM

note over IAM, KAFKA
  Every login attempt (success or failure)
  publishes a LoginAttemptEvent to Kafka,
  consumed by the Audit Service (AOP).
end note
@enduml
