# Root .dockerignore used by the frontend build whose context is the repo root.
# Exclude everything that the frontend image does not need to keep the build
# context small and fast.

# Version control / editors
.git
.gitignore
.idea
.vscode

# Backend (not needed by the frontend image)
backend
docs
logs
postman
veld

# Node / build artifacts
**/node_modules
frontend/dist
packages/*/node_modules

# Env / secrets
**/.env
**/.env.local
**/.env.*.local

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Docs
**/*.md
!packages/payment-gateway/README.md

