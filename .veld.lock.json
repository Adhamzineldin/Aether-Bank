{
  "version": 1,
  "modules": [
    {
      "name": "Transaction",
      "description": "Transaction service",
      "prefix": "/api/transaction_service/transactions",
      "actions": [
        {
          "name": "transfer",
          "method": "POST",
          "path": "/transfer",
          "input": "TransferRequest",
          "output": "TransactionResponse",
          "errors": [
            "InsufficientFunds",
            "InvalidAccount",
            "Unauthorized",
            "InvalidAmount",
            "invalidTarget"
          ],
          "errorStatuses": {
            "InsufficientFunds": 403,
            "InvalidAccount": 404,
            "InvalidAmount": 400,
            "Unauthorized": 401,
            "invalidTarget": 400
          },
          "middleware": []
        },
        {
          "name": "getAccountTransactions",
          "method": "GET",
          "path": "/account/:acountId",
          "input": "getAccountTransactionsRequest",
          "output": "PaginatedTransactionResponse",
          "middleware": []
        }
      ]
    }
  ],
  "models": [
    {
      "name": "TransferRequest",
      "fields": [
        {
          "name": "idempotencyKey",
          "type": "string"
        },
        {
          "name": "sourceAccountId",
          "type": "uuid"
        },
        {
          "name": "destinationAccountId",
          "type": "uuid"
        },
        {
          "name": "amount",
          "type": "decimal"
        },
        {
          "name": "currency",
          "type": "string"
        },
        {
          "name": "type",
          "type": "TransactionType"
        }
      ]
    },
    {
      "name": "TransactionResponse",
      "fields": [
        {
          "name": "referenceNumber",
          "type": "string"
        },
        {
          "name": "amount",
          "type": "decimal"
        },
        {
          "name": "status",
          "type": "TransactionStatus"
        },
        {
          "name": "timestamp",
          "type": "datetime"
        }
      ]
    },
    {
      "name": "getAccountTransactionsRequest",
      "fields": [
        {
          "name": "page",
          "type": "int",
          "default": "0"
        },
        {
          "name": "pageSize",
          "type": "int",
          "default": "20"
        }
      ]
    },
    {
      "name": "PaginatedTransactionResponse",
      "fields": [
        {
          "name": "content",
          "type": "TransactionResponse",
          "isArray": true
        },
        {
          "name": "pageNumber",
          "type": "int"
        },
        {
          "name": "pageSize",
          "type": "int"
        },
        {
          "name": "totalElements",
          "type": "long"
        },
        {
          "name": "totalPages",
          "type": "int"
        },
        {
          "name": "isLast",
          "type": "bool"
        }
      ]
    },
    {
      "name": "TransactionEvent",
      "fields": [
        {
          "name": "referenceNumber",
          "type": "string"
        },
        {
          "name": "sourceAccountId",
          "type": "uuid"
        },
        {
          "name": "destinationAccountId",
          "type": "uuid"
        },
        {
          "name": "amount",
          "type": "decimal"
        },
        {
          "name": "status",
          "type": "TransactionStatus"
        }
      ]
    },
    {
      "name": "TransferInitiatedEvent",
      "fields": [
        {
          "name": "transactionId",
          "type": "string"
        },
        {
          "name": "sourceAccountId",
          "type": "uuid"
        },
        {
          "name": "destinationAccountId",
          "type": "uuid"
        },
        {
          "name": "amount",
          "type": "decimal"
        },
        {
          "name": "currency",
          "type": "string"
        }
      ]
    }
  ]
}