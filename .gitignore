# ============================================================
# Aether Bank - Repository-wide ignore rules
# Covers both the Vite/React frontend and Spring Boot/Maven backend
# ============================================================

# ------------------------------------------------------------
# OS / filesystem noise
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Editors / IDEs
# ------------------------------------------------------------
.idea/
**/.idea/
*.iml
*.ipr
*.iws

.vscode/
**/.vscode/
!.vscode/extensions.json

.fleet/

# Eclipse / STS
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# ------------------------------------------------------------
# Logs / diagnostics
# ------------------------------------------------------------
logs/
*.log
*.out
*.err
*.pid
*.seed
*.stackdump
hs_err_pid*
replay_pid*

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Local environment / secrets
# Keep example templates tracked.
# ------------------------------------------------------------
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

*.local
application-local.properties
application-local.yml
application-local.yaml
application-*.local.properties
application-*.local.yml
application-*.local.yaml

docker-compose.override.yml
docker-compose.local.yml
docker-compose.*.local.yml

# ------------------------------------------------------------
# Frontend (Vite / React / TypeScript)
# ------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/.vite/
frontend/.cache/
frontend/.eslintcache
frontend/vite.config.ts.timestamp-*
frontend/*.tsbuildinfo

# ------------------------------------------------------------
# Backend (Spring Boot / Maven)
# ------------------------------------------------------------
backend/**/target/
backend/**/build/
backend/**/out/
backend/**/dependency-reduced-pom.xml
backend/**/.flattened-pom.xml
backend/**/surefire-reports/
backend/**/failsafe-reports/

# Generated artifacts inside backend modules
backend/**/*.class

# ------------------------------------------------------------
# Test / coverage outputs
# ------------------------------------------------------------
coverage/
.coverage
.nyc_output/
generated 


/veld/.veld.lock.json
/veld/.veld-cache.json
