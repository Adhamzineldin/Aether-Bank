// Account service module

import "../models/account.model.veld"

module Account {
  description: "Account service"
  prefix: /api/account

  action ListAccount {
    method: GET
    path: /
    output: AccountItem[]
  }

  action GetAccount {
    method: GET
    path: /:id
    output: AccountItem
    errors: [NotFound]
  }

  action CreateAccount {
    method: POST
    path: /
    input: CreateAccountInput
    output: AccountItem
  }
}
