// Account service module

import "../models/account.model.veld"

module Account {
  description: "Account service"
  prefix: /account
  
  action getBalance {
      method: GET
      path: /:accountId/balance
      output: AccountBalanceResponse
      errors: [AccountNotFoundError]
  }
  
  action doesAccountExist {
      method: GET
      path: /:accountId/exists
      output: bool
  }
  
}
