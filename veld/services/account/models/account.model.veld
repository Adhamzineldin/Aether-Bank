  
  model AccountBalanceResponse {
       accountId: uuid
       balance: decimal
       currency: string
  }
  
  model FundsSecuredEvent {
      transactionId: string
      status: string 
  }
  
  model InsufficientFundsEvent {
      transactionId: string
      reason: string
  }
  
  constants AccountSystemConfig {
      SYSTEM_USER_ID: uuid = "00000000-0000-0000-0000-000000000000"
  }
  
 
 