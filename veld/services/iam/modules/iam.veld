// Iam service module

import "../models/iam.model.veld"

module Iam {
  description: "Iam service"
  prefix: /api/iam

  action ListIam {
    method: GET
    path: /
    output: IamItem[]
  }

  action GetIam {
    method: GET
    path: /:id
    output: IamItem
    errors: [NotFound]
  }

  action CreateIam {
    method: POST
    path: /
    input: CreateIamInput
    output: IamItem
  }
}
