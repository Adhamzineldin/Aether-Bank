import "../models/mortgage.model.veld"

module mortgage {
  description: "Mortgage service"
  prefix: /mortgages

  action MortgageSubmit {
    description: "Submit a mortgage application"
    method: POST
    path: /application/submit
    input: MortgageApplication
    output: MortgageApplicationResponse
    errors: [
      MissingField:400,
      InvalidAmount:400
    ]
  }
}
