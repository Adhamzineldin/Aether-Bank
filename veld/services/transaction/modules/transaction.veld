// Transaction service module

import "../models/transaction.model.veld"

module Transaction {
  description: "Transaction service"
  prefix: /transaction

  action transfer {
    method: POST
    path: /transfer
    input: TransferRequest
    output: TransactionResponse
    errors: [
      InsufficientFunds,
      InvalidAccount,
      Unauthorized,
      InvalidAmount
    ]
  }

}
