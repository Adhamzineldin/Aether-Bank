enum TransactionType {
  DEPOSIT,
  WITHDRAWAL,
  TRANSFER,
}

enum TransactionStatus {
  PENDING,
  COMPLETED,
  FAILED,
}

model TransferRequest {
  sourceAccountId: uuid
  destinationAccountId: uuid
  amount: decimal
  currency: string
}

model TransactionResponse {
  referenceNumber: string
  amount: decimal
  status: TransactionStatus 
  timestamp: datetime
}

