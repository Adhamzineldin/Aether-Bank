enum TransactionType {
  DEPOSIT,
  WITHDRAWAL,
  TRANSFER,
}

enum TransactionStatus {
  PENDING,
  COMPLETED,
  FAILED,
}

model TransferRequest {
  sourceAccountId: uuid
  destinationAccountId: uuid
  amount: float
}

model TransactionResponse {
  referenceNumber: string
  amount: float
  status: TransactionStatus 
  timestamp: datetime
}