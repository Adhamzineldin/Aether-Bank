{
  "$schema": "https://veld.dev/schemas/veld.config.schema.json",
  "description": "bank system",

  "workspace": [
    {
      "name": "iam",
      "description": "",
      "input": "services/iam/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/iam-service" },
      "out": "../backend/iam-service/generated",
      "baseUrl": "http://localhost:4333"
    },
    {
      "name": "card",
      "description": "",
      "input": "services/card/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/card-service" },
      "out": "../backend/card-service/generated",
      "baseUrl": "http://card-service:3002"
    },
    {
      "name": "account",
      "description": "",
      "input": "services/account/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/account-service" },
      "out": "../backend/account-service/generated",
      "baseUrl": "http://account-service:3003"
    },
    {
      "name": "lending",
      "description": "",
      "input": "services/lending/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/lending-service" },
      "out": "../backend/lending-service/generated",
      "baseUrl": "http://lending-service:3004"
    },
    {
      "name": "notification",
      "description": "",
      "input": "services/notification/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/notification-service" },
      "out": "../backend/notification-service/generated",
      "baseUrl": "http://notification-service:3005"
    },
    {
      "name": "audit",
      "description": "",
      "input": "services/audit/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/audit-service" },
      "out": "../backend/audit-service/generated",
      "baseUrl": "http://localhost:8084"
    },
    {
      "name": "transaction",
      "description": "",
      "input": "services/transaction/main.veld",
      "backendConfig": { "target": "java", "framework": "spring", "dir": "../backend/transaction-service" },
      "out": "../backend/transaction-service/generated",
      "baseUrl": "http://localhost:2501",
      "consumes": ["iam", "audit", "account", "notification"]
    },
    {
      "name": "frontend",
      "description": "Frontend SDK — auto-consumes all backend services",
      "input": "app.veld",
      "frontendConfig": { "target": "react" },
      "out": "../frontend/src/generated",
      "baseUrl": "http://localhost:3000",
      "consumes": ["iam", "card", "account", "lending", "notification", "transaction"]
    }
  ]
}
