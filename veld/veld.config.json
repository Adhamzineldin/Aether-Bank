{
  "$schema": "https://veld.dev/schemas/veld.config.schema.json",

  "workspace": [
    {
      "name": "account",
      "description": "",
      "input": "services/account/modules/account.veld",
      "backendConfig": { "target": "java" },
      "out": "../backend/account-service/generated",
      "baseUrl": "http://account-service:3001"
    },
    {
      "name": "card",
      "description": "",
      "input": "services/card/modules/card.veld",
      "backendConfig": { "target": "java" },
      "out": "../backend/card-service/generated",
      "baseUrl": "http://card-service:3002"
    },
    {
      "name": "iam",
      "description": "",
      "input": "services/iam/modules/iam.veld",
      "backendConfig": { "target": "java" },
      "out": "../backend/iam-service/generated",
      "baseUrl": "http://iam-service:3003"
    },
    {
      "name": "lending",
      "description": "",
      "input": "services/lending/modules/lending.veld",
      "backendConfig": { "target": "java" },
      "out": "../backend/lending-service/generated",
      "baseUrl": "http://lending-service:3004"
    },
    {
      "name": "notification",
      "description": "",
      "input": "services/notification/modules/notification.veld",
      "backendConfig": { "target": "java" },
      "out": "../backend/notification-service/generated",
      "baseUrl": "http://notification-service:3005"
    },
    {
      "name": "transaction",
      "description": "",
      "input": "services/transaction/modules/transaction.veld",
      "backendConfig": { "target": "java" },
      "out": "../backend/transaction-service/generated",
      "baseUrl": "http://transaction-service:3006"
    },
    {
      "name": "frontend",
      "description": "Frontend SDK — auto-consumes all backend services",
      "frontendConfig": { "target": "react" },
      "out": "../frontend/src/generated",
      "baseUrl": "http://localhost:3000",
      "consumes": ["account", "card", "iam", "lending", "notification", "transaction"]
    }
  ]
}
